{
  "name": "aesys",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "db:app:generate": "drizzle-kit generate --config drizzle.app.config.ts",
    "db:app:migrate": "drizzle-kit migrate --config drizzle.app.config.ts",
    "db:app:push": "drizzle-kit push --config drizzle.app.config.ts",
    "db:app:studio": "drizzle-kit studio --config drizzle.app.config.ts",
    "db:config:generate": "drizzle-kit generate --config drizzle.config.config.ts",
    "db:config:migrate": "drizzle-kit migrate --config drizzle.config.config.ts",
    "db:config:push": "drizzle-kit push --config drizzle.config.config.ts",
    "db:config:studio": "drizzle-kit studio --config drizzle.config.config.ts",
    "auth:generate": "pnpm dlx @better-auth/cli@latest generate --config lib/auth.ts --output lib/db/app/auth-schema.ts",
    "db:app:create-admin": "tsx --conditions=react-server scripts/create-admin.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@electric-sql/pglite": "^0.5.3",
    "@hookform/resolvers": "^5.4.0",
    "better-auth": "^1.6.19",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.79.0",
    "recharts": "3.8.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.11.0",
    "sharp": "^0.35.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
