# Copy to `.env.local` and fill in. Never commit real secrets.

# --- Demo mode (no external Postgres) ---
# Set DEMO_MODE=true to run against an embedded PostgreSQL (PGlite, in-process).
# Migrations + demo accounts are seeded automatically on first start, so you can
# `pnpm dev` and sign in immediately — no database to install, no APP_DATABASE_URL
# needed. (Demo mode is also assumed when APP_DATABASE_URL is unset.)
DEMO_MODE=true

# --- App database (PostgreSQL) — primary application data + auth ---
# Used when DEMO_MODE is not enabled. Safe to leave as-is while demoing.
APP_DATABASE_URL=postgres://postgres:postgres@localhost:5432/aesys

# --- App config database (SQLite) — operational/local config ---
# File path; the directory is created automatically.
CONFIG_DATABASE_URL=./.data/config.db

# --- better-auth ---
# Generate with: openssl rand -base64 32 (must be >= 32 chars / high entropy)
BETTER_AUTH_SECRET=
# Public origin. Its origin is auto-added to the CSRF trusted-origins list.
BETTER_AUTH_URL=http://localhost:3000
# Optional: extra CSRF-trusted origins (comma-separated), e.g. a separate
# frontend domain. The BETTER_AUTH_URL origin is always trusted.
# BETTER_AUTH_TRUSTED_ORIGINS=https://app.example.com,https://www.example.com

# --- Client ---
# Only needed if the API is served from a different origin than the app.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- First admin (bootstrap) ---
# There is no public sign-up; seed the first SUPER_ADMIN with:
#   pnpm db:app:create-admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
ADMIN_NAME=Administrator
